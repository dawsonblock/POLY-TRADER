[Unit]
Description=Polymarket Python Oracle (Binance Price Feeder)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/poly-trader
ExecStart=/opt/poly-trader/venv/bin/python3 /opt/poly-trader/oracles/poly_oracle.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
